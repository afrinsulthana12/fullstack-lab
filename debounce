/**
 * @param {Function} fn
 * @param {number} t milliseconds
 * @return {Function}
 */
var debounce = function(fn, t) {
    let timeoutId;

    return function(...args) {
        // Clear the existing timer whenever the function is called
        clearTimeout(timeoutId);

        // Set a new timer
        timeoutId = setTimeout(() => {
            fn(...args);
        }, t);
    };
};
